# Configuracao de API Keys
# Copie este arquivo para .env e preencha suas chaves

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (fallback)
OPENAI_API_KEY=sk-your-key-here

# GitHub (para monitoramento)
GITHUB_TOKEN=ghp_your-token-here

# Configuracoes do ecossistema
ECOSYSTEM_LOG_LEVEL=INFO
ECOSYSTEM_DATA_DIR=./data
