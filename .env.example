# OLMO_ROADMAP local environment template
# Copy to .env and fill only the variables you actually use.
#
# PowerShell:
#   Copy-Item .env.example .env
#
# Bash:
#   cp .env.example .env

# Research / QA scripts
GEMINI_API_KEY=
GEMINI_MODEL=
PERPLEXITY_API_KEY=
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LOCAL=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Cross-repo inbox handoff (producer -> consumer)
OLMO_INBOX=

# Local observability stack (docker compose + OTel -> Langfuse)
LANGFUSE_DB_PASSWORD=
CLICKHOUSE_PASSWORD=
REDIS_PASSWORD=
MINIO_PASSWORD=
ENCRYPTION_KEY=
LANGFUSE_SALT=
NEXTAUTH_SECRET=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Base64 of "LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY"
LANGFUSE_AUTH_HEADER=
