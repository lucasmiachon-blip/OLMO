# =============================================================
# Configuracao do Ecossistema AI Agent
# =============================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# NUNCA commitar .env (ja esta no .gitignore)
# =============================================================

# --- OBRIGATORIOS ---

# Anthropic (Claude API - modelo principal)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- RECOMENDADAS ---

# OpenAI (ChatGPT 5.4 como auditor/cross-validation)
OPENAI_API_KEY=sk-your-key-here

# GitHub (MCP Server - 5000 req/h free)
GITHUB_TOKEN=ghp_your-token-here

# Brave Search (MCP Server - 2000 req/mo free)
BRAVE_API_KEY=BSA-your-key-here

# HuggingFace (Modelos open-source)
HF_TOKEN=hf_your-token-here

# Google AI / Gemini (contexto 1M tokens)
GEMINI_API_KEY=AIza-your-key-here

# --- NOTION (criar em notion.so/my-integrations) ---
# Token unico para read + write
NOTION_TOKEN_KEY=ntn_your-token-here

# Notion Database IDs (copiar da URL do Notion: notion.so/[workspace]/[DB_ID])
NOTION_MASTERPIECE_DB=your-masterpiece-db-id-here
NOTION_MASTERPIECE_DS=collection://your-masterpiece-datasource-here
NOTION_TASKS_DB=your-tasks-db-id-here
NOTION_TASKS_DS=collection://your-tasks-datasource-here
NOTION_EMAILS_DIGEST_DB=your-emails-digest-db-id-here
NOTION_EMAILS_DIGEST_DS=collection://your-emails-digest-datasource-here

# --- EMAIL (contas para daily-briefing) ---
EMAIL_INSTITUTIONAL=your-institutional@email.com
EMAIL_PERSONAL=your-personal@email.com

# --- OLLAMA (local, $0) ---

# URL do Ollama local (padrao: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo local padrao
OLLAMA_MODEL=llama3.3


# --- DOCKER STACK (Langfuse + OTel self-hosted) ---
# Required for: docker compose up
# Values below are examples for local dev — change for production
LANGFUSE_DB_PASSWORD=langfuse_local
CLICKHOUSE_PASSWORD=clickhouse_local
REDIS_PASSWORD=redis_local
MINIO_PASSWORD=minio_local_secret
ENCRYPTION_KEY=generate-a-random-64-char-hex-string
LANGFUSE_SALT=generate-a-unique-salt
NEXTAUTH_SECRET=generate-a-base64-secret

# --- OTEL (telemetria nativa Claude Code) ---
# Ativar para medir tokens, custo e erros por sessao (Tier 0 antifragile)
# Backend recomendado: Langfuse (cloud free 50k eventos/mes ou self-host MIT)
# CLAUDE_CODE_ENABLE_TELEMETRY=1
# OTEL_METRICS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_METRIC_EXPORT_INTERVAL=10000

# --- ECOSSISTEMA ---

ECOSYSTEM_LOG_LEVEL=INFO
ECOSYSTEM_DATA_DIR=./data
# SQLITE_PATH=data/knowledge.db
# Obsidian vault: caminho absoluto recomendado (ex: C:\Dev\Projetos\Organizacao\data\obsidian-vault)
OBSIDIAN_VAULT=data/obsidian-vault
# Usar CLI quando disponivel (app Obsidian rodando). Fallback: file write.
OBSIDIAN_CLI_ENABLED=true

# --- ZOTERO ---
# MCP: Local API (Zotero aberto + Advanced > Allow other applications)
# Script atualizar_tema --fetch: Web API para busca na biblioteca
# https://www.zotero.org/settings/keys - criar key e pegar Library ID
# ZOTERO_API_KEY=
# ZOTERO_LIBRARY_ID=
# SNAPSHOT_DIR=data/snapshots
