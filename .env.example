# =============================================================
# Configuracao do Ecossistema AI Agent
# =============================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# NUNCA commitar .env (ja esta no .gitignore)
# =============================================================

# --- OBRIGATORIOS ---

# Anthropic (Claude API - modelo principal)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- RECOMENDADAS ---

# OpenAI (ChatGPT 5.4 como auditor/cross-validation)
OPENAI_API_KEY=sk-your-key-here

# GitHub (MCP Server - 5000 req/h free)
GITHUB_TOKEN=ghp_your-token-here

# Brave Search (MCP Server - 2000 req/mo free)
BRAVE_API_KEY=BSA-your-key-here

# HuggingFace (Modelos open-source)
HF_TOKEN=hf_your-token-here

# Google AI / Gemini (contexto 1M tokens)
GOOGLE_AI_KEY=AIza-your-key-here

# --- NOTION (criar em notion.so/my-integrations) ---
# Token unico para read + write
NOTION_TOKEN_KEY=ntn_your-token-here

# --- OLLAMA (local, $0) ---

# URL do Ollama local (padrao: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
# Modelo local padrao
OLLAMA_MODEL=llama3.3

# --- ECOSSISTEMA ---

ECOSYSTEM_LOG_LEVEL=INFO
ECOSYSTEM_DATA_DIR=./data
# SQLITE_PATH=data/knowledge.db
# OBSIDIAN_VAULT=data/obsidian-vault
# SNAPSHOT_DIR=data/snapshots
